# ── Supabase 대시보드 연동 (필수) ─────────────────────────────────────────
# https://supabase.com/dashboard → 프로젝트 선택 → Project Settings → API
#
# Project URL → 아래 첫 번째
# anon (public) 키 → 아래 두 번째  (service_role 키는 절대 프론트/저장소에 넣지 마세요)
#
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# 실제 값은 이 파일이 아니라 .env.local 에만 넣으세요 (.env.local 은 Git 에 포함되지 않음)
# cp .env.local.example .env.local 후 .env.local 을 수정합니다.

# ── 학생 로그인용 내부 이메일 도메인 ───────────────────────────────────────
# Auth에 등록한 이메일이 `학번정규화@이도메인` 과 일치해야 합니다.
NEXT_PUBLIC_STUDENT_EMAIL_DOMAIN=student.tuk-archive.local

# ── 교수 회원가입 허용 도메인 (학교 이메일) ────────────────────────────────
# 예: tukorea.ac.kr 이면 name@tukorea.ac.kr 만 교수 회원가입 가능
NEXT_PUBLIC_PROFESSOR_EMAIL_DOMAIN=tukorea.ac.kr

# ── DB 비밀번호 (npm run db:push) ─────────────────────────────────────────
# 대시보드 → Project Settings → Database → Database password
# 아래에 본인 비밀번호만 입력 (따옴표 없이). .env.local 에 동일 키로 복사합니다.
#
SUPABASE_DB_PASSWORD=
#
# 그 다음: npm run db:push
# (supabase link 없이 동작합니다.)
# 이미 link 했다면: npm run db:push:linked
