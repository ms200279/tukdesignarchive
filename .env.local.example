# ── Supabase 대시보드 연동 (필수) ─────────────────────────────────────────
# https://supabase.com/dashboard → 프로젝트 선택 → Project Settings → API
#
# Project URL → 아래 첫 번째
# anon (public) 키 → 아래 두 번째  (service_role 키는 절대 프론트/저장소에 넣지 마세요)
#
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# 실제 값은 이 파일이 아니라 .env.local 에만 넣으세요 (.env.local 은 Git 에 포함되지 않음)
# cp .env.local.example .env.local 후 .env.local 을 수정합니다.

# ── 학생 로그인용 내부 이메일 도메인 ───────────────────────────────────────
# Auth에 등록한 이메일이 `학번정규화@이도메인` 과 일치해야 합니다.
NEXT_PUBLIC_STUDENT_EMAIL_DOMAIN=student.tuk-archive.local

# ── DB 마이그레이션 푸시 (npm run db:push) ────────────────────────────────
# 대시보드 → Project Settings → Database → Database password
# 아래 한 줄을 .env.local 에 추가 (이 예시 파일에는 넣지 마세요)
#
# SUPABASE_DB_PASSWORD=데이터베이스_비밀번호
#
# 그 다음 프로젝트 루트에서:
#   npm run db:push
#
# (supabase link 없이 동작합니다. 대화형 입력으로 멈추지 않습니다.)
#
# 이미 `supabase link` 를 해 둔 경우:
#   npm run db:push:linked
