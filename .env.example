# =============================================================================
# TUK Design Archive — environment template
# Copy to `.env.local` (Next.js) and fill values. Never commit `.env.local`.
#
# Visibility (see also README or AGENTS.md):
#   PUBLIC  — NEXT_PUBLIC_* : embedded in browser bundle; treat as non-secret
#             but still protect (anon key is public by design; abuse = rate limits).
#   SERVER  — no NEXT_PUBLIC_ prefix : Node only (Server Actions, Route Handlers,
#             middleware runs on edge — only vars actually read there ship).
#             Never import `@/config/server` from Client Components.
# =============================================================================

# --- Required (public) — Supabase project ------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# --- Optional (public) — defaults match supabase/migrations ------------------
# Storage bucket id (RLS + work_files.storage_bucket default)
# NEXT_PUBLIC_WORK_FILES_BUCKET=work-originals

# Sign-in email suffixes (must match Auth users you create)
# NEXT_PUBLIC_STUDENT_EMAIL_DOMAIN=student.tuk-archive.local
# NEXT_PUBLIC_PROFESSOR_EMAIL_DOMAIN=tukorea.ac.kr

# Signed URL lifetimes (seconds, positive integers)
# NEXT_PUBLIC_COVER_PREVIEW_SIGNED_URL_TTL_SEC=900
# NEXT_PUBLIC_WORK_FILE_DOWNLOAD_SIGNED_URL_TTL_SEC=1800

# --- Required for `npm run db:push` (server / local CLI only) --------------
# Either full Postgres URL:
# SUPABASE_DB_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
# Or password only (script builds URL from NEXT_PUBLIC_SUPABASE_URL):
SUPABASE_DB_PASSWORD=

# Do NOT set in frontend code or .env for production edge unless you know you need it:
# SUPABASE_SERVICE_ROLE_KEY=
